# ─────────────────────────────────────────────────────────────
# Apex Lift — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# LINE Notify Token
# 1. ไปที่ https://notify-bot.line.me/my/
# 2. กด "Generate token"
# 3. ตั้งชื่อ เช่น "Apex Lift Leads"
# 4. เลือก Group หรือ Chat ที่จะรับ notification
# 5. Copy token มาใส่ด้านล่าง
VITE_LINE_NOTIFY_TOKEN=your_line_notify_token_here
